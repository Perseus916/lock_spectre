# Root environment template for local development
# Do not commit your real .env file.

# Firebase project mapping used by local tooling/scripts
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID

# Cloud Functions email settings (local emulator fallback)
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-app-password
EMAIL_SERVICE=gmail

# Android/Firebase placeholders (actual Android app config comes from app/google-services.json)
FIREBASE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com
FIREBASE_API_KEY=YOUR_API_KEY_HERE

